use std::{print}

external 23 fn move(x: Int, y: Int)
external 24 fn write(s: String)

struct Crawler {
}

/*
PLAYER="🧙‍♂️"
ENVIRONMENT="⋅:🪨🧱🌱🌊🚪"
ENEMIES="🕷️🐍🦇🐙🦎🦠👻💀🧚"
WEAPONS="🗡️🏹🛡️🪄"
LOOT="💎💍🏆🗝️"
RESOURCES="❤️💙💰🪙📜"
*/

impl Crawler {
	fn tick() {
		move(1, 0)
		print("tick!")
	}
}

#[host_call]
fn main() -> Crawler {
	move(1,2)
	write("🐙")

	move(2,3)
	write("🕷️")

	Crawler {

	}
}
