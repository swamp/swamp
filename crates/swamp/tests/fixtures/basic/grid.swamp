use core::{assert, panic}
use std::{print}

#[test]
fn add_remove() {
    mut grid: Grid<Int; (10,10)> = []

    x = grid.get(0,0)
    assert(x == 0, "should be 0 at start")

    grid.set(1,0,42)
    assert(grid.get(1,0) == 42, "should be 42 after setting")

    grid.set(4,8,-101)
    assert(grid.get(4,8) == -101, "should be -101 after setting")
}
