use core::{assert}
use std::{print}

#[test]
fn add() {
  print("Hello, world!")
  a = 10 + 42
  print('a:{a}') // string interpolation works in new runtime!
    assert(a == 52, "add doesn't work")
}

#[test]
fn div() {
  assert(-10 / 2 == -5, "div doesn't work")
}

#[test]
fn float_mul() {
	r = 1.5 * 8.0
	print('r:{r}') // string interpolation works in new runtime!
  assert(r == 12.0, "float mul problem")
}

#[test]
fn float_div() {
  assert(-42.0 / 4.0 == -10.5, "float div doesn't work")
}

struct Point {
  x: Int,
  y: Int,
}

#[test]
fn literal_struct() {
  a = Point { x: 10, y: 20 }
  print('x:{a.x}, y:{a.y}')
  assert(a.x == 10, "struct doesn't work")
  assert(a.y == 20, "struct doesn't work")
}
