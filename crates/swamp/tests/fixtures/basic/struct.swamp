use core::{assert}
use std::{print}

struct Point {
  x: Int,
  y: Int,
}


impl Point {
	fn add(self, other: Point) -> Point {
		Point { x: self.x + other.x, y: self.y + other.y }
	}
}

#[test]
fn add_points() {
	a = Point { x: 10, y: 20 }
	b = Point { x: 30, y: 40 }
	c = a.add(b)
	print('x:{c.x}, y:{c.y}')
	assert(c.x == 40, 'x value is wrong')
	assert(c.y == 60, 'y value is wrong')
}


#[test]
fn literal_struct() {
  a = Point { x: 10, y: 20 }
  print('x:{a.x}, y:{a.y}')
  assert(a.x == 10, 'x value is wrong')
  assert(a.y == 20, 'y value is wrong')
}