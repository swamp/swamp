use core::{assert}
use std::{print}

struct Thing {
  a: Int,
  b: Int,
}

struct Another {
  array: Vec<Thing, 10>,
}


#[test]
fn vec_assign_and_subscript() {

  another = Another {
    array: [
      Thing { a: 11, b:  1 },
      Thing { b:  2, a: 12 }, // Intentionally swapped
      Thing { a: 13, b:  3 },
    ]
  }

  second_thing = another.array[1]

  assert(second_thing.a == 12, 'second_thing.b is wrong')
  assert(second_thing.b == 2, 'second_thing.b is wrong')
  print('amazing if this works: a: {second_thing.a} b: {second_thing.b}')

  assert(another.array[0].a == 11, 'another.array[0].a is wrong')
  assert(another.array[1].b == 2, 'another.array[1].b is wrong')
  assert(another.array[2].b == 3, 'another.array[2].b is wrong')
}


