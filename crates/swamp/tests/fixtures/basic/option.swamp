use core::{assert}
use std::{print}

#[test]
fn option_some() {
  a: Int? = 10
  assert(a, 'a should be Some')
}

#[test]
fn option_none() {
  a: Int? = none
  assert(!a, 'a should be None')
}


struct Attacker {
  health: Int,
}

struct Unit {
  attacker: Attacker?
}

#[test]
fn when_in_when() {
    unit: Unit? = none

    when unit {
      when unit.attacker {
      }
    }
}


#[test]
fn option_param(unit: Unit?) {
  when unit {
  }
}
