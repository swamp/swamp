#[test]
fn test_string_to_string() {
    s = "hello world!"
    result = s.to_string()
    assert(result == "\"hello world!\"", 'result is wrong {result}')
}

struct MinimalStruct {
    field: String,
}

#[test]
fn string_field_on_minimal_struct() {
    m = MinimalStruct {
        field: "hello",
    }
    result = m.to_string()
    assert(result == "\"hello world!\"", 'field in minimal result is wrong {result}')
}




