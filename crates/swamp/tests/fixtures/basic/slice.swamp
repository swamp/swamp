use core::{assert}
use std::{print}

struct Thing {
		x: [Int; 4],
}

#[test]
fn test_index() {
	mut thing = Thing { .. }
	thing.x[0] = 1
	thing.x[1] = 2
	thing.x[2] = 3
	//print('x[0]:{thing.x[0]}, x[1]:{thing.x[1]}, x[2]:{thing.x[2]}')
	assert(thing.x[0] == 1, 'x[0] value is wrong')
	assert(thing.x[1] == 2, 'x[1] value is wrong')
	assert(thing.x[2] == 3, 'x[2] value is wrong')
}