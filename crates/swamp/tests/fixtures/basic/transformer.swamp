#[test]
fn find_in_array() {
    a = [1, 2, 3, 4]
    maybe_int = a.find(|x| x == 2)
    when maybe_int {
        print('found value: {maybe_int}')
        assert(maybe_int == 2, 'should find 2 in array {maybe_int}')
    } else {
        panic('should not panic, did not find value')
    }
}
