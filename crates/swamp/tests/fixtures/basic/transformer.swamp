use core::{assert}
use std::{print}

struct Thing {
    a: Int,
    b: Int,
}

struct Another {
    things: Vec<Int; 4>,
}

#[test]
fn filter() {
    another = Another {
        things: [1, 2, 3, 4],
    }
    even_numbers : Vec<Int; 8> = another.things.filter(|x| x % 2 == 0)
    assert(even_numbers.len() == 2, 'should have 2 even numbers {even_numbers.len()}')
}

